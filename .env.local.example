DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db
JWT_SECRET=change-this-secret-for-your-demo

# Local Wi-Fi server binding
PORT=3000
HOST=0.0.0.0
HTTPS=false
HTTPS_KEY_PATH=certs/localhost-key.pem
HTTPS_CERT_PATH=certs/localhost.pem

# Leave these blank for same-origin access.
# The app will use http://<laptop-ip>:3000 automatically when opened on mobile.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SOCKET_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional comma-separated allow-list for extra local origins.
# Example: http://192.168.1.23:3000,http://localhost:3000
LOCAL_NETWORK_ORIGINS=
