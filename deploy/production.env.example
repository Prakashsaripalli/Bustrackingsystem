NODE_ENV=production
PORT=3000
HOST=0.0.0.0
HTTPS=false

# Replace with your real public domain.
# IMPORTANT: Let's Encrypt needs a real FQDN like adityauniversitybustracking.com or adityauniversitybustracking.in
NEXT_PUBLIC_APP_URL=https://adityauniversitybustracking.com
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SOCKET_URL=

# PostgreSQL production database.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/app_db

# Use a long random secret in production.
JWT_SECRET=replace-with-a-long-random-secret

# Optional: if you want stricter Socket.IO CORS, add comma-separated public origins.
LOCAL_NETWORK_ORIGINS=https://adityauniversitybustracking.com
